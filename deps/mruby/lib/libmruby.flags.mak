# GNU make is required to use this file.
MRUBY_PACKAGE_DIR_GNU := $(shell dirname "$(lastword $(MAKEFILE_LIST))")
MRUBY_PACKAGE_DIR != dirname "$(MRUBY_PACKAGE_DIR_GNU)"
MRUBY_CC = cl.exe
MRUBY_CFLAGS = /nologo /W3 /MD /O2 /D_CRT_SECURE_NO_WARNINGS /we4013 /DMRB_STACK_EXTEND_DOUBLING /DMRB_USE_SET /DHAVE_MRUBY_IO_GEM /DMRB_USE_RATIONAL /DMRB_USE_COMPLEX /DMRB_USE_BIGINT /DMRB_USE_DEBUG_HOOK /I"$(MRUBY_PACKAGE_DIR)\include"
MRUBY_CXX = cl.exe
MRUBY_CXXFLAGS = /nologo /W3 /MD /O2 /D_CRT_SECURE_NO_WARNINGS /EHs /DMRB_STACK_EXTEND_DOUBLING /DMRB_USE_SET /DHAVE_MRUBY_IO_GEM /DMRB_USE_RATIONAL /DMRB_USE_COMPLEX /DMRB_USE_BIGINT /DMRB_USE_DEBUG_HOOK /I"$(MRUBY_PACKAGE_DIR)\include"
MRUBY_AS = cc
MRUBY_ASFLAGS = -D"MRB_USE_SET" -D"HAVE_MRUBY_IO_GEM" -D"MRB_USE_RATIONAL" -D"MRB_USE_COMPLEX" -D"MRB_USE_BIGINT" -D"MRB_USE_DEBUG_HOOK" -I"$(MRUBY_PACKAGE_DIR)\include"
MRUBY_OBJC = cc
MRUBY_OBJCFLAGS = -D"MRB_USE_SET" -D"HAVE_MRUBY_IO_GEM" -D"MRB_USE_RATIONAL" -D"MRB_USE_COMPLEX" -D"MRB_USE_BIGINT" -D"MRB_USE_DEBUG_HOOK" -I"$(MRUBY_PACKAGE_DIR)\include"
MRUBY_LD = link.exe
MRUBY_LDFLAGS = /NOLOGO /DEBUG /INCREMENTAL:NO /OPT:ICF /OPT:REF /LIBPATH:$(MRUBY_PACKAGE_DIR)/lib
MRUBY_LDFLAGS_BEFORE_LIBS = 
MRUBY_LIBS = libmruby.lib ws2_32.lib wsock32.lib ws2_32.lib
MRUBY_LIBMRUBY_PATH = $(MRUBY_PACKAGE_DIR)/lib/libmruby.lib
